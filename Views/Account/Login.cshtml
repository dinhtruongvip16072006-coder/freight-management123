@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - VanChuyenPBL3</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * {
            font-family: 'Be Vietnam Pro', sans-serif;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            margin: 0;
            background: #f5f5f5;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .auth-card {
            width: 100%;
            max-width: 400px;
            background: #fff;
            border-radius: 8px;
            padding: 40px 36px;
            box-shadow: 0 2px 16px rgba(0,0,0,.08);
        }

        .auth-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #222;
            text-align: center;
            margin-bottom: 28px;
        }

        .form-label {
            font-size: .85rem;
            font-weight: 600;
            color: #555;
            margin-bottom: 6px;
        }

        .form-control {
            border-radius: 6px;
            border: 1px solid #ddd;
            padding: 11px 14px;
            font-size: .92rem;
            color: #333;
        }

            .form-control:focus {
                border-color: #2e7d32;
                box-shadow: 0 0 0 3px rgba(46,125,50,.12);
            }

            .form-control::placeholder {
                color: #bbb;
            }

        .btn-submit {
            width: 100%;
            background: #2e7d32;
            border: none;
            color: #fff;
            padding: 12px;
            border-radius: 6px;
            font-weight: 700;
            font-size: .95rem;
            margin-top: 6px;
            transition: background .2s;
            cursor: pointer;
        }

            .btn-submit:hover {
                background: #1b5e20;
            }

        .divider {
            text-align: center;
            color: #ccc;
            margin: 18px 0;
            font-size: .82rem;
            position: relative;
        }

            .divider::before, .divider::after {
                content: '';
                position: absolute;
                top: 50%;
                height: 1px;
                width: 44%;
                background: #eee;
            }

            .divider::before {
                left: 0;
            }

            .divider::after {
                right: 0;
            }

        .link-register {
            display: block;
            text-align: center;
            color: #555;
            text-decoration: none;
            font-size: .88rem;
        }

            .link-register strong {
                color: #2e7d32;
            }

            .link-register:hover strong {
                text-decoration: underline;
            }

        .alert-danger {
            background: #fff5f5;
            border: 1px solid #fcc;
            color: #c62828;
            border-radius: 6px;
            font-size: .88rem;
            padding: 10px 14px;
        }

        .home-link {
            position: fixed;
            top: 20px;
            left: 20px;
            color: #999;
            text-decoration: none;
            font-size: .85rem;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .home-link:hover {
                color: #2e7d32;
            }
    </style>
</head>
<body>
    <a href="/Home/Index" class="home-link"><i class="bi bi-arrow-left"></i> Trang chủ</a>
    <div class="auth-card">
        <div class="auth-title">Đăng nhập</div>
        @if (ViewBag.Error != null)
        {
            <div class="alert-danger mb-3"><i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success mb-3" style="border-radius:6px;font-size:.88rem">@TempData["Success"]</div>
        }
        <form method="post" action="/Account/Login">
            <div class="mb-3">
                <label class="form-label">Email <span style="color:red">*</span></label>
                <input type="email" name="email" class="form-control" placeholder="email@example.com" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Mật khẩu <span style="color:red">*</span></label>
                <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu" required />
            </div>
            <button type="submit" class="btn-submit">Đăng nhập</button>
        </form>
        <div class="divider">hoặc</div>
        <a href="/Account/Register" class="link-register">Chưa có tài khoản? <strong>Đăng ký ngay</strong></a>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
