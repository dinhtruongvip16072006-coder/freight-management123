@model IEnumerable<FreightManagement.Models.KhoHang>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Quản lý kho hàng";
}
<div class="page-header">
    <div><h4><i class="bi bi-building me-2"></i>Danh sách kho hàng</h4><small>Tổng: @Model.Count() kho</small></div>
    <a href="/Admin/Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Dashboard</a>
</div>
<div class="row g-3 mb-4">
    @foreach (var k in Model)
    {
        var pct = k.SucChua > 0 ? (int)((double)k.SoLuongHienTai / k.SucChua * 100) : 0;
        var color = pct >= 80 ? "#d32f2f" : pct >= 50 ? "#e65100" : "#2e7d32";
        <div class="col-md-4">
            <div style="background:#fff;border-radius:14px;padding:22px;box-shadow:0 2px 8px rgba(0,0,0,.05);border-top:4px solid @color">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px">
                    <div>
                        <h6 style="font-weight:700;color:#222;margin:0">@k.TenKho</h6>
                        <small style="color:#999"><i class="bi bi-geo-alt me-1"></i>@k.DiaChiKho</small>
                    </div>
                    <span style="font-size:1.8rem">🏭</span>
                </div>
                <div style="margin-bottom:8px">
                    <div style="display:flex;justify-content:space-between;font-size:.82rem;margin-bottom:4px">
                        <span style="color:#666">Sức chứa</span>
                        <span style="font-weight:700;color:@color">@k.SoLuongHienTai / @k.SucChua kiện</span>
                    </div>
                    <div style="background:#e8f5e9;border-radius:6px;height:8px">
                        <div style="background:@color;height:8px;border-radius:6px;width:@pct%;transition:width .5s"></div>
                    </div>
                </div>
                <div style="font-size:.82rem;color:#777">
                    <i class="bi bi-person me-1"></i>Quản lý: <strong>@(k.QuanLyKho?.HoTen ?? "Chưa phân công")</strong>
                </div>
            </div>
        </div>
    }
</div>
