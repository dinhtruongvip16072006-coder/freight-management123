@* ===== Views/Driver/Delivering.cshtml ===== *@
@model IEnumerable<FreightManagement.Models.DonHang>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Đang giao hàng";
}
<div class="page-header">
    <div><h4><i class="bi bi-truck me-2"></i>Đang giao hàng</h4><small>Xác nhận khi đã giao thành công đến tay người nhận</small></div>
</div>
<div class="data-table">
    <table class="table">
        <thead><tr><th>Mã đơn</th><th>Người nhận</th><th>Địa chỉ nhận</th><th>Hàng hóa</th><th>Chi phí</th><th>Thao tác</th></tr></thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center py-4" style="color:#aaa">Không có đơn nào đang giao</td></tr>
            }
            @foreach (var d in Model)
            {
                <tr>
                    <td><strong style="color:#6a1b9a">#@d.MaDon.ToString("D5")</strong></td>
                    <td><div style="font-weight:600">@d.TenNguoiNhan</div><small style="color:#999">@d.SdtNguoiNhan</small></td>
                    <td><small>@d.DiaChiNhan</small></td>
                    <td><small>@(d.MoTaHang ?? "—") (@d.SoLuong kiện)</small></td>
                    <td><strong>@d.ChiPhi.ToString("N0") ₫</strong></td>
                    <td>
                        <form method="post" action="/Driver/GiaoThanhCong">
                            <input type="hidden" name="maDon" value="@d.MaDon" />
                            <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('Xác nhận đã giao hàng thành công?')">
                                <i class="bi bi-check-circle me-1"></i>Đã giao thành công
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
