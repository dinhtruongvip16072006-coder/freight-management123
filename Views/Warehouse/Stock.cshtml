@* ===== Views/Warehouse/Stock.cshtml ===== *@
@model IEnumerable<FreightManagement.Models.HangTrongKho>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Hàng trong kho";
}
<div class="page-header">
    <div><h4><i class="bi bi-archive me-2"></i>Hàng đang trong kho</h4></div>
</div>
<div class="data-table">
    <table class="table">
        <thead><tr><th>Mã đơn</th><th>Kho</th><th>Khách hàng</th><th>Hàng hóa</th><th>Tài xế</th><th>Thời gian vào kho</th><th>Trạng thái</th></tr></thead>
        <tbody>
            @foreach (var h in Model)
            {
                <tr>
                    <td><strong style="color:#2e7d32">#@h.MaDon.ToString("D5")</strong></td>
                    <td>@h.KhoHang?.TenKho</td>
                    <td>@h.DonHang?.KhachHang?.HoTen</td>
                    <td><small>@(h.DonHang?.MoTaHang ?? "—") (@h.DonHang?.SoLuong kiện)</small></td>
                    <td>@(h.DonHang?.TaiXe?.HoTen ?? "Chưa gán")</td>
                    <td><small>@h.ThoiGianVaoKho.ToString("dd/MM/yyyy HH:mm")</small></td>
                    <td><span class="badge-status badge-warehouse">@h.DonHang?.TrangThai</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>
