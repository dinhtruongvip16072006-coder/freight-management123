@* ===== Views/Warehouse/Exported.cshtml ===== *@
@model IEnumerable<FreightManagement.Models.HangTrongKho>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Đơn hàng xuất kho";
}
<div class="page-header">
    <div><h4><i class="bi bi-box-arrow-up me-2"></i>Danh sách đơn đã xuất kho</h4></div>
    <a href="/Warehouse/Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Dashboard</a>
</div>
<div class="data-table">
    <table class="table">
        <thead><tr><th>Mã đơn</th><th>Kho</th><th>Khách hàng</th><th>Hàng hóa</th><th>Tài xế</th><th>Vào kho</th><th>Xuất kho</th><th>Trạng thái</th></tr></thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="text-center py-4" style="color:#aaa">Chưa có đơn nào xuất kho</td></tr>
            }
            @foreach (var h in Model)
            {
                <tr>
                    <td><strong style="color:#2e7d32">#@h.MaDon.ToString("D5")</strong></td>
                    <td>@h.KhoHang?.TenKho</td>
                    <td>@h.DonHang?.KhachHang?.HoTen</td>
                    <td><small>@(h.DonHang?.MoTaHang ?? "—") (@h.DonHang?.SoLuong kiện)</small></td>
                    <td>@(h.DonHang?.TaiXe?.HoTen ?? "—")</td>
                    <td><small style="color:#999">@h.ThoiGianVaoKho.ToString("dd/MM/yy HH:mm")</small></td>
                    <td><small style="color:#e65100">@h.ThoiGianXuatKho?.ToString("dd/MM/yy HH:mm")</small></td>
                    <td>
                        @{
                            var cls = h.DonHang?.TrangThai switch
                            {
                                "Đang vận chuyển" => "badge-shipping",
                                "Đã giao" => "badge-delivered",
                                _ => "badge-pending"
                            };
                        }
                        <span class="badge-status @cls">@h.DonHang?.TrangThai</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
