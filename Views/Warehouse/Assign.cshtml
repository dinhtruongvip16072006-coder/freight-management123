@model IEnumerable<FreightManagement.Models.DonHang>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Gán tài xế";
}
<div class="page-header">
    <div><h4><i class="bi bi-person-badge me-2"></i>Gán tài xế cho đơn hàng</h4><small>Đơn đã vào kho, chờ gán tài xế</small></div>
</div>
<div class="data-table">
    <table class="table">
        <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Hàng hóa</th><th>Địa chỉ nhận</th><th>Kho</th><th>Chi phí</th><th>Gán tài xế</th></tr></thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center py-4" style="color:#aaa">Không có đơn nào cần gán tài xế</td></tr>
            }
            @foreach (var d in Model)
            {
                <tr>
                    <td><strong style="color:#2e7d32">#@d.MaDon.ToString("D5")</strong></td>
                    <td><div style="font-weight:600">@d.KhachHang?.HoTen</div></td>
                    <td><small>@(d.MoTaHang ?? "—") (@d.SoLuong kiện)</small></td>
                    <td><small>@d.DiaChiNhan</small></td>
                    <td><small>@d.HangTrongKho?.KhoHang?.TenKho</small></td>
                    <td><strong>@d.ChiPhi.ToString("N0") ₫</strong></td>
                    <td>
                        @if (d.MaTX == null)
                        {
                            <form method="post" action="/Warehouse/GanTaiXe" style="display:flex;gap:6px">
                                <input type="hidden" name="maDon" value="@d.MaDon" />
                                <select name="maTX" class="form-select form-select-sm">
                                    <option value="">-- Chọn tài xế --</option>
                                    @foreach (var tx in ViewBag.TaiXes as List<FreightManagement.Models.User> ?? new())
                                    {
                                        <option value="@tx.UserId">@tx.HoTen (@tx.SoDienThoai)</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-primary btn-sm">Gán</button>
                            </form>
                        }
                        else
                        {
                            <span style="color:#2e7d32;font-weight:600">🚚 @d.TaiXe?.HoTen</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
